{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "env": ["NEXT_PUBLIC_TWITCH_CLIENT_ID", "TWITCH_CLIENT_SECRET"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:ci": {
      "dependsOn": ["^build"]
    },
    "create": {
      "cache": false
    },
    "deploy": {
      "cache": false
    },
    "preview": {
      "cache": false
    },
    "destroy:local": {
      "cache": false
    },
    "destroy:ci": {
      "cache": false
    }
  }
}
