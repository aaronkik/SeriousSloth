{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "test:ci": {
      "env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_REGION",
        "PULUMI_ACCESS_TOKEN",
        "PR_NUMBER"
      ]
    },
    "deploy:staging": {
      "env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_REGION",
        "PULUMI_ACCESS_TOKEN"
      ]
    },
    "deploy:prod": {
      "env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_REGION",
        "PULUMI_ACCESS_TOKEN"
      ]
    },
    "destroy:ci": {
      "cache": false,
      "env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_REGION",
        "PULUMI_ACCESS_TOKEN",
        "PR_NUMBER"
      ]
    }
  }
}
